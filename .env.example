# ============================================================
# RestoPilot — variables d'environnement (template)
# ============================================================
# Copiez ce fichier en .env.local pour le développement :
#   cp .env.example .env.local
# puis remplissez les valeurs ci-dessous.
#
# Pour Netlify : saisissez ces mêmes variables dans
# Site settings > Environment variables (onglet "Production"
# ET "Preview" si vous voulez des deploy previews).
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Dashboard Supabase > Settings > API
# URL du projet (ex : https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (safe côté client — RLS protège les données)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic / Claude ──────────────────────────────────────
# Console Anthropic > API Keys
# Utilisée uniquement côté serveur par /api/mercuriale-import
# pour extraire les produits des mercuriales PDF / image.
ANTHROPIC_API_KEY=
